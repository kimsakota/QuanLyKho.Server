@{
    ViewData["Title"] = "Đường lối hai chiến lược cách mạng";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts: Be Vietnam Pro (hỗ trợ tiếng Việt) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          xintegrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        body {
            font-family: 'Be Vietnam Pro', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            overflow: hidden; /* Prevent scrolling */
            font-size: 18px;
        }

        h1, h2, h3 {
            font-family: 'Be Vietnam Pro', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        /* Animation Classes */
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        .fade-in {
            animation: fadeIn 0.8s ease-out forwards;
            opacity: 0;
        }

        .slide-content-enter {
            animation: slideContentEnter 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        @@keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            to {
                opacity: 1;
            }
        }

        @@keyframes slideContentEnter {
            from {
                opacity: 0;
                transform: scale(0.98) translateY(10px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        /* Glassmorphism Utilities */
        .glass-panel {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

            .glass-card:hover {
                background: rgba(51, 65, 85, 0.8);
                transform: translateY(-2px);
                border-color: rgba(250, 204, 21, 0.3);
            }

        /* Gradient Background Animation */
        .animated-bg {
            background: linear-gradient(-45deg, #0f172a, #1e3a8a, #312e81, #111827);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }

        @@keyframes gradientBG {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }
    </style>

</head>
<body class="animated-bg text-white h-screen w-screen flex flex-col">

    <!-- Main Content Area -->
    <div id="app" class="flex-1 w-full h-full relative flex items-center justify-center p-2 md:p-4 lg:p-6">
        <!-- Slide content will be injected here -->
    </div>

    <!-- Control Bar -->
    <div id="controlBar" class="fixed bottom-0 left-0 w-full h-20 bg-gradient-to-t from-slate-950 to-transparent z-50 flex items-center justify-between px-8 pb-4">
        <div class="text-slate-400 text-sm font-medium hidden md:block">
            <i class="fa-solid fa-graduation-cap mr-2"></i>Lịch sử Đảng CSVN
        </div>

        <div class="flex items-center space-x-6 bg-slate-900/80 backdrop-blur-md px-6 py-2 rounded-full border border-slate-700 shadow-2xl">
            <button onclick="prevSlide()" class="hover:text-yellow-400 transition-colors p-2 text-2xl" title="Slide trước (Mũi tên trái)">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <span id="slide-counter" class="font-mono text-xl font-bold text-yellow-500 min-w-[70px] text-center">
                1 / 26
            </span>

            <button onclick="nextSlide()" class="hover:text-yellow-400 transition-colors p-2 text-2xl" title="Slide sau (Mũi tên phải)">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>

        <div class="text-slate-400 text-sm hidden md:block">
            Nhấn <span class="border border-slate-600 rounded px-1 text-xs">←</span> <span class="border border-slate-600 rounded px-1 text-xs">→</span> để điều hướng
        </div>
    </div>

    <script>
        // ====== ICON UTILS ======
        function getFaIcon(name) {
            switch (name) {
                case 'map-pin': return 'fa-location-dot';
                case 'target': return 'fa-bullseye';
                case 'link': return 'fa-link';
                case 'award': return 'fa-medal';
                case 'star': return 'fa-star';
                case 'trending-up': return 'fa-arrow-trend-up';
                case 'flame': return 'fa-fire';
                case 'shield': return 'fa-shield-halved';
                case 'users': return 'fa-users';
                case 'flag': return 'fa-flag';
                case 'check-circle': return 'fa-circle-check';
                case 'history': return 'fa-clock-rotate-left';
                case 'zap': return 'fa-bolt';
                case 'globe': return 'fa-earth-americas';
                case 'heart': return 'fa-heart';
                case 'lightbulb': return 'fa-lightbulb';
                case 'book-open': return 'fa-book-open';
                case 'star-outline': return 'fa-star-half-stroke';
                default: return 'fa-circle';
            }
        }

        function iconHtml(name, extraClasses) {
            const fa = getFaIcon(name);
            return `<i class="fa-solid ${fa} ${extraClasses || ''}"></i>`;
        }

        // ====== SLIDE DATA ======
        const slides = [
            // Slide 1: Title
            {
                type: 'title',
                content: {
                    title: 'Đường lối hai chiến lược cách mạng',
                    subtitle: 'Giai đoạn 1954 - 1975',
                    footer: 'Lịch sử Đảng Cộng sản Việt Nam'
                }
            },
            // Slide 2: Menu
            {
                type: 'content',
                content: {
                    title: 'Nội dung chính',
                    subtitle: 'Câu hỏi nghiên cứu & Chủ trương chiến lược',
                    points: [
                        { icon: 'map-pin', text: 'Tình hình Việt Nam sau Hiệp định Giơnevơ 1954' },
                        { icon: 'target', text: 'Nội dung đường lối cách mạng - Đại hội III (9/1960)' },
                        { icon: 'link', text: 'Mối quan hệ biện chứng giữa hai chiến lược' },
                        { icon: 'award', text: 'Ý nghĩa lịch sử của đường lối' }
                    ]
                }
            },
            // Slide 3: Section I
            { type: 'section', content: { number: 'I', title: 'Tình hình Việt Nam sau Hiệp định Giơnevơ 1954' } },
            // Slide 4: Context
            {
                type: 'content',
                content: {
                    title: 'Bối cảnh lịch sử',
                    subtitle: 'Thắng lợi và bước ngoặt mới',
                    points: [
                        { icon: 'star', text: 'Chiến thắng Điện Biên Phủ (1954) kết thúc kháng chiến chống Pháp' },
                        { icon: 'award', text: 'Hiệp định Giơnevơ được ký kết, quốc tế công nhận độc lập chủ quyền' },
                        { icon: 'trending-up', text: 'Miền Bắc hoàn toàn giải phóng, đi lên chủ nghĩa xã hội' }
                    ]
                }
            },
            // Slide 5: Challenge
            {
                type: 'content',
                content: {
                    title: 'Thách thức lịch sử',
                    subtitle: 'Âm mưu của Đế quốc Mỹ',
                    points: [
                        { icon: 'flame', text: 'Mỹ ngang nhiên phá hoại Hiệp định Giơnevơ' },
                        { icon: 'shield', text: 'Thiết lập chính quyền tay sai, biến miền Nam thành thuộc địa kiểu mới' },
                        { icon: 'zap', text: 'Âm mưu chia cắt lâu dài đất nước Việt Nam' }
                    ]
                }
            },
            // Slide 6: Highlight
            {
                type: 'highlight',
                content: {
                    title: 'Đặc điểm lớn nhất',
                    mainText: 'Đất nước tạm thời bị chia cắt làm hai miền',
                    subPoints: [
                        'Miền Bắc: Cách mạng Xã hội chủ nghĩa',
                        'Miền Nam: Cách mạng Dân tộc Dân chủ Nhân dân'
                    ]
                }
            },
            // Slide 7: Image Map
            {
                type: 'image',
                content: {
                    title: 'Chia cắt tại vĩ tuyến 17',
                    description: 'Sông Bến Hải - Cầu Hiền Lương: Ranh giới chia cắt tạm thời hai miền Nam - Bắc.',
                    icon: 'map-pin',
                    imageUrl: '/images/lichsudang/vituyen17.jpg'   // <-- thêm dòng này
                }
            },

            // Slide 8: Section II
            { type: 'section', content: { number: 'II', title: 'Đường lối cách mạng - Đại hội Đảng III (9/1960)' } },
            // Slide 9: Long text
            {
                type: 'quote',
                content: {
                    title: 'Đường lối chiến lược chung',
                    subtitle: 'Văn kiện Đại hội III',
                    text: 'Tăng cường đoàn kết toàn dân, kiên quyết đấu tranh giữ vững hòa bình, đẩy mạnh cách mạng xã hội chủ nghĩa ở miền Bắc, đồng thời đẩy mạnh cách mạng dân tộc dân chủ nhân dân ở miền Nam, thực hiện thống nhất nước nhà...'
                }
            },
            // Slide 10: Goals
            {
                type: 'goals',
                content: {
                    title: 'Mục tiêu chung',
                    goals: [
                        { icon: 'flag', text: 'Thống nhất nước nhà' },
                        { icon: 'shield', text: 'Độc lập dân tộc' },
                        { icon: 'users', text: 'Dân chủ nhân dân' },
                        { icon: 'trending-up', text: 'Đất nước giàu mạnh' },
                        { icon: 'globe', text: 'Bảo vệ hòa bình thế giới' }
                    ]
                }
            },
            // Slide 11: North Mission
            {
                type: 'content',
                content: {
                    title: 'Nhiệm vụ Miền Bắc',
                    subtitle: 'Cách mạng Xã hội chủ nghĩa',
                    points: [
                        { icon: 'trending-up', text: 'Xây dựng căn cứ địa cách mạng vững mạnh của cả nước' },
                        { icon: 'shield', text: 'Trở thành hậu phương lớn cho tiền tuyến miền Nam' },
                        { icon: 'zap', text: 'Chi viện sức người, sức của; chuẩn bị đánh thắng chiến tranh phá hoại' }
                    ]
                }
            },
            // Slide 12: South Mission
            {
                type: 'content',
                content: {
                    title: 'Nhiệm vụ Miền Nam',
                    subtitle: 'Cách mạng Dân tộc Dân chủ Nhân dân',
                    points: [
                        { icon: 'flame', text: 'Đánh đuổi đế quốc Mỹ và tay sai' },
                        { icon: 'shield', text: 'Bảo vệ miền Bắc Xã hội chủ nghĩa' },
                        { icon: 'flag', text: 'Giải phóng miền Nam, tiến tới thống nhất đất nước' }
                    ]
                }
            },
            // Slide 13: Comparison
            {
                type: 'twocolumn',
                content: {
                    title: 'So sánh nhiệm vụ hai miền',
                    leftTitle: 'Miền Bắc',
                    leftIcon: 'star',
                    leftColor: 'blue',
                    leftPoints: ['Xây dựng CNXH', 'Căn cứ địa vững mạnh', 'Hậu phương lớn', 'Chi viện miền Nam'],
                    rightTitle: 'Miền Nam',
                    rightIcon: 'flame',
                    rightColor: 'red',
                    rightPoints: ['Đánh đuổi Mỹ', 'Tiền tuyến lớn', 'Bảo vệ miền Bắc', 'Thống nhất Tổ quốc']
                }
            },
            // Slide 14: Role North
            {
                type: 'role',
                content: {
                    title: 'Vai trò chiến lược',
                    subtitle: 'Cách mạng XHCN ở Miền Bắc',
                    icon: 'star',
                    mainRole: 'QUYẾT ĐỊNH NHẤT',
                    description: 'Đối với sự nghiệp phát triển của toàn bộ cách mạng Việt Nam và sự nghiệp thống nhất nước nhà.',
                    color: 'blue'
                }
            },
            // Slide 15: Role South
            {
                type: 'role',
                content: {
                    title: 'Vai trò chiến lược',
                    subtitle: 'Cách mạng DTDCND ở Miền Nam',
                    icon: 'target',
                    mainRole: 'QUYẾT ĐỊNH TRỰC TIẾP',
                    description: 'Đối với sự nghiệp chống Mỹ cứu nước, giải phóng miền Nam, hoàn thành cuộc cách mạng dân tộc dân chủ.',
                    color: 'red'
                }
            },
            // Slide 16: Image Illustrate
            {
                type: 'image',
                content: {
                    title: 'Hậu phương & Tiền tuyến',
                    description: 'Miền Bắc "Thóc không thiếu một cân, quân không thiếu một người" chi viện cho miền Nam ruột thịt.',
                    icon: 'users',
                    imageUrl: '/images/lichsudang/hauphuong-tientuyen.jpg' // <-- thêm dòng này
                }
            },

            // Slide 17: Section III
            { type: 'section', content: { number: 'III', title: 'Mối quan hệ giữa hai chiến lược cách mạng' } },
            // Slide 18: Relation Unity
            {
                type: 'content',
                content: {
                    title: 'Mối quan hệ thống nhất',
                    subtitle: 'Tuy khác nhau về nhiệm vụ nhưng gắn bó mật thiết vì:',
                    points: [
                        { icon: 'users', text: 'Do một Đảng duy nhất (Đảng Lao động Việt Nam) lãnh đạo' },
                        { icon: 'history', text: 'Cùng thuộc một tiến trình cách mạng chung của cả nước' },
                        { icon: 'flag', text: 'Chung một mục tiêu chiến lược: Độc lập, Thống nhất' },
                        { icon: 'target', text: 'Chung kẻ thù nguy hiểm nhất: Đế quốc Mỹ xâm lược' }
                    ]
                }
            },
            // Slide 19: Diagram
            {
                type: 'diagram',
                content: {
                    title: 'Sơ đồ quan hệ biện chứng'
                }
            },
            // Slide 20: Section IV
            { type: 'section', content: { number: 'IV', title: 'Ý nghĩa lịch sử của đường lối' } },
            // Slide 21: Practical Meaning
            {
                type: 'content',
                content: {
                    title: 'Ý nghĩa thực tiễn',
                    subtitle: 'Kim chỉ nam cho hành động',
                    points: [
                        { icon: 'lightbulb', text: 'Giương cao ngọn cờ độc lập dân tộc gắn liền với CNXH' },
                        { icon: 'check-circle', text: 'Kết hợp sức mạnh dân tộc với sức mạnh thời đại' },
                        { icon: 'users', text: 'Huy động cao nhất sức mạnh tổng hợp của cả hai miền Nam - Bắc' },
                        { icon: 'award', text: 'Dẫn đến thắng lợi vĩ đại Mùa Xuân năm 1975' }
                    ]
                }
            },
            // Slide 22: Theoretical Meaning
            {
                type: 'content',
                content: {
                    title: 'Ý nghĩa lý luận',
                    subtitle: 'Đóng góp vào kho tàng Mác-Lênin',
                    points: [
                        { icon: 'book-open', text: 'Thể hiện tư duy độc lập, tự chủ và sáng tạo của Đảng' },
                        { icon: 'star', text: 'Giải quyết thành công vấn đề "một đất nước, hai chế độ" chưa có tiền lệ' },
                        { icon: 'globe', text: 'Làm phong phú thêm lý luận về cách mạng giải phóng dân tộc' }
                    ]
                }
            },
            // Slide 23: Conclusion
            {
                type: 'conclusion',
                content: {
                    title: 'Tổng kết',
                    points: [
                        'Đường lối đúng đắn, sáng tạo, độc đáo chưa từng có tiền lệ.',
                        'Là nhân tố hàng đầu quyết định thắng lợi của cuộc kháng chiến chống Mỹ.',
                        'Biểu tượng của bản lĩnh và trí tuệ Việt Nam.'
                    ]
                }
            },
            // Slide 24: Quiz 1
            {
                type: 'quiz',
                content: {
                    title: 'Câu hỏi ôn tập 1',
                    questions: [{
                        q: 'Đại hội nào của Đảng đã đề ra đường lối tiến hành đồng thời hai chiến lược cách mạng?',
                        options: ['Đại hội II (1951)', 'Đại hội III (1960)', 'Đại hội IV (1976)', 'Đại hội VI (1986)'],
                        answer: 'B'
                    }]
                }
            },
            // Slide 25: Quiz 2
            {
                type: 'quiz',
                content: {
                    title: 'Câu hỏi ôn tập 2',
                    questions: [{
                        q: 'Vai trò chiến lược của Cách mạng Xã hội chủ nghĩa ở miền Bắc là gì?',
                        options: ['Quyết định trực tiếp', 'Quyết định nhất', 'Vai trò hỗ trợ', 'Quan trọng thứ yếu'],
                        answer: 'B'
                    }]
                }
            },
            // Slide 26: Quiz 3
            {
                type: 'quiz',
                content: {
                    title: 'Câu hỏi ôn tập 3',
                    questions: [{
                        q: 'Vai trò chiến lược của Cách mạng Dân tộc Dân chủ Nhân dân ở miền Nam là gì?',
                        options: ['Quyết định nhất', 'Quyết định trực tiếp', 'Quyết định gián tiếp', 'Vai trò hậu phương'],
                        answer: 'B'
                    }]
                }
            }
        ];

        let currentSlide = 0;

        // ====== RENDER FUNCTIONS ======
        function renderSlideContent(slide) {
            const c = slide.content;
                const commonContainer =
        "w-full max-w-7xl mx-auto flex flex-col items-center justify-center slide-content-enter h-[calc(100vh-6rem)] origin-center scale-[0.75]";


            switch (slide.type) {
                case 'title':
                    return `
                    <div class="${commonContainer} text-center py-6">
                        <div class="mb-8 relative">
                            <div class="absolute inset-0 bg-yellow-400 blur-[60px] opacity-20 rounded-full"></div>
                            ${iconHtml('star', 'relative text-9xl md:text-[9rem] text-yellow-400 drop-shadow-[0_0_15px_rgba(250,204,21,0.5)] animate-pulse')}
                        </div>
                        <h1 class="text-6xl md:text-8xl lg:text-9xl font-extrabold text-white mb-6 leading-tight drop-shadow-2xl">
                            ${c.title}
                        </h1>
                        <div class="w-40 h-2 bg-yellow-500 mx-auto rounded-full mb-8 shadow-[0_0_10px_rgba(234,179,8,0.8)]"></div>
                        <p class="text-4xl md:text-6xl text-yellow-300 font-medium mb-10">
                            ${c.subtitle}
                        </p>
                        <div class="inline-block bg-slate-900/50 backdrop-blur px-8 py-3 rounded-lg border border-slate-700 text-slate-300 text-2xl font-semibold">
                            ${c.footer}
                        </div>
                    </div>`;

                case 'section':
                    return `
                    <div class="${commonContainer} text-center">
                        <div class="glass-panel p-16 md:p-20 rounded-[3rem] border-t-4 border-t-yellow-400 relative overflow-hidden w-full h-full flex items-center justify-center">
                            <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-blue-500 rounded-full blur-[100px] opacity-20"></div>
                            <div class="absolute bottom-0 left-0 -mb-10 -ml-10 w-64 h-64 bg-yellow-500 rounded-full blur-[100px] opacity-10"></div>

                            <div class="text-[12rem] leading-none font-black text-white/10 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 select-none">
                                ${c.number}
                            </div>
                            <div class="relative z-10">
                                <span class="block text-3xl md:text-4xl text-yellow-400 font-bold mb-6">Phần ${c.number}</span>
                                <h2 class="text-6xl md:text-8xl font-bold text-white leading-tight">${c.title}</h2>
                            </div>
                        </div>
                    </div>`;

                case 'content':
                    return `
                    <div class="${commonContainer} px-4 pt-4">
                        <div class="text-center mb-8 w-full">
                            <h2 class="text-5xl md:text-7xl font-bold text-white mb-3 drop-shadow-lg">${c.title}</h2>
                            ${c.subtitle ? `<p class="text-3xl md:text-4xl text-yellow-300 font-medium">${c.subtitle}</p>` : ''}
                        </div>
                        <div class="grid gap-5 w-full">
                            ${c.points.map((p, idx) => `
                                <div class="glass-card flex items-center p-7 md:p-9 rounded-2xl w-full fade-in-up" style="animation-delay: ${idx * 0.15}s">
                                    <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-gradient-to-br from-blue-600 to-blue-900 flex items-center justify-center flex-shrink-0 shadow-lg border border-blue-400/30 mr-7 md:mr-9">
                                        ${iconHtml(p.icon, 'text-3xl md:text-5xl text-yellow-400')}
                                    </div>
                                    <p class="text-3xl md:text-4xl text-slate-100 font-medium leading-relaxed">${p.text}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>`;

                case 'quote':
                    return `
                    <div class="${commonContainer}">
                        <div class="text-center mb-8">
                            <h2 class="text-5xl md:text-7xl font-bold text-white">${c.title}</h2>
                        </div>
                        <div class="glass-panel p-10 md:p-14 rounded-3xl relative border-l-8 border-yellow-500 w-full">
                             ${iconHtml('book-open', 'absolute top-6 right-6 text-7xl text-white/5')}
                             <div class="text-7xl text-yellow-500 absolute top-4 left-4">“</div>
                             <p class="text-3xl md:text-5xl text-white leading-relaxed text-justify italic px-6 relative z-10">
                                ${c.text}
                             </p>
                             <div class="text-6xl text-yellow-500 absolute bottom-4 right-4 leading-none">”</div>
                             <div class="mt-6 text-right text-2xl md:text-3xl text-yellow-400 font-bold">— ${c.subtitle}</div>
                        </div>
                    </div>`;

                case 'highlight':
                    return `
                    <div class="${commonContainer}">
                        <h2 class="text-5xl md:text-7xl font-bold text-white mb-8 text-center">${c.title}</h2>
                        <div class="bg-gradient-to-br from-red-900/80 to-blue-900/80 p-1 rounded-[3rem] shadow-2xl w-full">
                            <div class="bg-slate-900/90 rounded-[2.8rem] p-10 md:p-16 text-center relative overflow-hidden backdrop-blur-xl h-full flex flex-col justify-center">
                                <div class="absolute top-0 left-1/2 transform -translate-x-1/2 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>

                                ${iconHtml('map-pin', 'text-7xl md:text-8xl text-yellow-500 mb-6 block relative z-10')}
                                <p class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-yellow-600 mb-10 relative z-10 uppercase leading-snug">
                                    ${c.mainText}
                                </p>
                                <div class="grid md:grid-cols-2 gap-6 relative z-10">
                                    ${c.subPoints.map(sp => `
                                        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
                                            <div class="text-green-400 text-4xl mb-3"><i class="fa-solid fa-check"></i></div>
                                            <p class="text-3xl text-white font-medium">${sp}</p>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        </div>
                    </div>`;

                case 'goals':
                    return `
                    <div class="${commonContainer} pt-4">
                        <h2 class="text-5xl md:text-7xl font-bold text-white mb-8 text-center">${c.title}</h2>
                        <div class="flex flex-wrap justify-center gap-6 md:gap-8">
                            ${c.goals.map((g, i) => `
                                <div class="glass-card flex flex-col items-center justify-center p-7 rounded-2xl w-48 md:w-64 h-48 md:h-64 text-center hover:scale-105 transition-transform duration-300 fade-in-up" style="animation-delay: ${i * 0.1}s">
                                    ${iconHtml(g.icon, 'text-5xl md:text-6xl text-yellow-400 mb-4 drop-shadow-md')}
                                    <p class="text-2xl md:text-3xl text-white font-semibold leading-snug">${g.text}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>`;

                case 'twocolumn':
                    return `
                    <div class="${commonContainer} pt-4">
                        <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 text-center">${c.title}</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full items-start">
                            <!-- Left Column -->
                            <div class="glass-panel rounded-3xl p-8 border-t-4 border-${c.leftColor}-500 flex flex-col">
                                <div class="flex items-center mb-5 border-b border-white/10 pb-3">
                                    <div class="w-16 h-16 rounded-xl bg-${c.leftColor}-600 flex items-center justify-center mr-4 shadow-lg">
                                        ${iconHtml(c.leftIcon, 'text-3xl text-white')}
                                    </div>
                                    <h3 class="text-4xl md:text-5xl font-bold text-white">${c.leftTitle}</h3>
                                </div>
                                <ul class="space-y-3">
                                    ${c.leftPoints.map(p => `
                                        <li class="flex items-start text-3xl md:text-4xl text-slate-200">
                                            <span class="text-${c.leftColor}-400 mr-3 mt-1 text-xl"><i class="fa-solid fa-chevron-right"></i></span>
                                            ${p}
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                            <!-- Right Column -->
                            <div class="glass-panel rounded-3xl p-8 border-t-4 border-${c.rightColor}-500 flex flex-col">
                                <div class="flex items-center mb-5 border-b border-white/10 pb-3">
                                    <div class="w-16 h-16 rounded-xl bg-${c.rightColor}-600 flex items-center justify-center mr-4 shadow-lg">
                                        ${iconHtml(c.rightIcon, 'text-3xl text-white')}
                                    </div>
                                    <h3 class="text-4xl md:text-5xl font-bold text-white">${c.rightTitle}</h3>
                                </div>
                                <ul class="space-y-3">
                                    ${c.rightPoints.map(p => `
                                        <li class="flex items-start text-3xl md:text-4xl text-slate-200">
                                            <span class="text-${c.rightColor}-400 mr-3 mt-1 text-xl"><i class="fa-solid fa-chevron-right"></i></span>
                                            ${p}
                                        </li>
                                    `).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>`;

                case 'role':
                    const gradient = c.color === 'blue' ? 'from-blue-600 to-blue-800' : 'from-red-600 to-red-800';
                    const iconColor = c.color === 'blue' ? 'text-blue-200' : 'text-red-200';
                    return `
                    <div class="${commonContainer} text-center">
                        <div class="glass-panel p-10 md:p-16 rounded-[3rem] w-full relative overflow-hidden group hover:shadow-[0_0_50px_rgba(255,255,255,0.1)] transition-all duration-500 h-full flex flex-col justify-center">
                            <div class="absolute top-0 right-0 w-96 h-96 bg-${c.color}-600 rounded-full blur-[120px] opacity-30 -mr-20 -mt-20"></div>

                            <h2 class="text-4xl md:text-5xl font-bold text-slate-300 mb-4">${c.subtitle}</h2>
                            <h1 class="text-6xl md:text-8xl font-extrabold text-white mb-8">${c.title}</h1>

                            <div class="inline-block relative">
                                <div class="absolute inset-0 bg-gradient-to-r ${gradient} blur-lg opacity-70"></div>
                                <div class="relative bg-gradient-to-r ${gradient} px-10 py-6 rounded-2xl shadow-2xl border border-white/20 transform group-hover:scale-105 transition-transform duration-300">
                                    <div class="flex flex-col items-center">
                                        ${iconHtml(c.icon, `text-7xl mb-4 ${iconColor}`)}
                                        <span class="text-5xl md:text-7xl font-extrabold text-white uppercase drop-shadow-lg">${c.mainRole}</span>
                                    </div>
                                </div>
                            </div>

                            <p class="text-3xl md:text-5xl text-slate-200 mt-10 max-w-5xl mx-auto leading-relaxed font-light">
                                ${c.description}
                            </p>
                        </div>
                    </div>`;

                case 'image':
                    return `
                    <div class="${commonContainer}">
                        <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 text-center">${c.title}</h2>
                        <div class="w-full bg-slate-800/50 rounded-3xl p-4 border border-slate-700 h-[65vh] flex flex-col items-center justify-center relative overflow-hidden group">
                             <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent z-10"></div>

                             <div class="w-full h-full flex items-center justify-center relative">
                                <div class="absolute inset-0 opacity-20 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-slate-500 to-slate-900"></div>

                                ${
                                    c.imageUrl
                                        ? `<img src="${c.imageUrl}"
                                                 alt="${c.title}"
                                                 class="max-h-full max-w-full object-contain rounded-2xl shadow-2xl border border-slate-600" />`
                                        : `${iconHtml(c.icon || 'image', 'text-[13rem] text-slate-600 opacity-50')}`
                                }
                             </div>

                             <div class="absolute bottom-0 left-0 w-full p-6 z-20 text-center">
                                 <p class="text-3xl md:text-4xl text-white font-medium bg-slate-900/80 backdrop-blur-sm inline-block px-8 py-4 rounded-2xl shadow-xl border border-slate-600">
                                    ${c.description}
                                 </p>
                             </div>
                        </div>
                    </div>`;


                case 'diagram':
                    return `
                    <div class="${commonContainer}">
                         <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 text-center">${c.title}</h2>
                         <div class="glass-panel p-8 md:p-12 rounded-3xl w-full flex flex-col items-center justify-center relative h-[65vh]">
                            <div class="bg-yellow-500 text-blue-900 px-8 py-4 rounded-xl text-3xl md:text-4xl font-bold shadow-lg z-20 mb-10 transform hover:scale-110 transition-transform">
                                ĐẢNG CỘNG SẢN VIỆT NAM
                            </div>

                            <div class="w-full max-w-4xl flex justify-between relative">
                                <div class="absolute top-0 left-1/2 w-0.5 h-full bg-yellow-500/50 -translate-x-1/2"></div>
                                <div class="absolute top-1/2 left-0 w-full h-0.5 bg-yellow-500/50 -translate-y-1/2"></div>

                                <div class="w-[45%] bg-blue-900/80 border-2 border-blue-500 rounded-2xl p-6 text-center z-10 shadow-xl hover:-translate-y-2 transition-transform">
                                    <h3 class="text-3xl md:text-4xl font-bold text-blue-300 mb-2">MIỀN BẮC</h3>
                                    <p class="text-2xl text-white mb-2">Xây dựng CNXH</p>
                                    <div class="bg-blue-600 px-3 py-1 rounded inline-block text-base font-bold mt-2">Quyết định nhất</div>
                                </div>

                                <div class="w-[45%] bg-red-900/80 border-2 border-red-500 rounded-2xl p-6 text-center z-10 shadow-xl hover:-translate-y-2 transition-transform">
                                    <h3 class="text-3xl md:text-4xl font-bold text-red-300 mb-2">MIỀN NAM</h3>
                                    <p class="text-2xl text-white mb-2">Cách mạng DTDCND</p>
                                    <div class="bg-red-600 px-3 py-1 rounded inline-block text-base font-bold mt-2">Quyết định trực tiếp</div>
                                </div>
                            </div>

                            <div class="mt-10 bg-green-700 text-white px-10 py-4 rounded-2xl text-3xl md:text-4xl font-bold shadow-2xl z-20 border-2 border-green-400">
                                THỐNG NHẤT TỔ QUỐC (1975)
                            </div>
                         </div>
                    </div>`;

                case 'conclusion':
                    return `
                    <div class="${commonContainer}">
                        <div class="mb-6 relative inline-block">
                             <div class="absolute inset-0 bg-yellow-400 blur-2xl opacity-40"></div>
                             ${iconHtml('award', 'relative text-9xl text-yellow-400')}
                        </div>
                        <h2 class="text-6xl md:text-8xl font-bold text-white mb-10">${c.title}</h2>
                        <div class="grid gap-6 w-full max-w-5xl">
                            ${c.points.map((p, idx) => `
                                <div class="glass-card p-8 rounded-2xl text-left flex items-center transform transition-all hover:translate-x-2 border-l-8 border-l-yellow-400">
                                    <span class="text-5xl md:text-6xl font-black text-white/10 mr-6">0${idx + 1}</span>
                                    <p class="text-3xl md:text-4xl text-slate-100">${p}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>`;

                case 'quiz':
                    return `
                    <div class="${commonContainer}">
                        <div class="text-center mb-8">
                            <span class="bg-yellow-500 text-blue-900 font-bold px-4 py-1 rounded-full text-base mb-4 inline-block">Kiểm tra kiến thức</span>
                            <h2 class="text-6xl md:text-8xl font-bold text-white">${c.title}</h2>
                        </div>

                        <div class="w-full max-w-4xl relative">
                             ${c.questions.map((q, qIndex) => `
                                <div class="glass-panel p-10 md:p-12 rounded-3xl">
                                    <p class="text-5xl md:text-6xl font-semibold text-white mb-10 leading-snug">
                                        <span class="text-yellow-400 font-bold mr-2">Q:</span>
                                        ${q.q}
                                    </p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        ${q.options.map((o, oIndex) => {
                                            const letter = String.fromCharCode(65 + oIndex);
                                            return `
                                                <button type="button"
                                                        class="quiz-option group relative overflow-hidden text-left w-full p-6 rounded-xl bg-slate-800/50 hover:bg-blue-600/80 border border-slate-600 hover:border-blue-400 transition-all duration-300"
                                                        data-q="${qIndex}"
                                                        data-letter="${letter}">
                                                    <div class="flex items-center relative z-10">
                                                        <span class="w-11 h-11 rounded-full bg-slate-700 group-hover:bg-white group-hover:text-blue-600 flex items-center justify-center font-bold mr-4 transition-colors text-xl">${letter}</span>
                                                        <span class="text-3xl md:text-4xl text-slate-200 group-hover:text-white font-medium">${o}</span>
                                                    </div>
                                                </button>
                                            `;
                                        }).join('')}
                                    </div>

                                    <!-- Feedback Box -->
                                    <div class="mt-8 quiz-answer hidden transform transition-all duration-500 origin-top" data-q="${qIndex}">
                                        <div class="rounded-2xl p-6 flex items-center border-l-8 text-white shadow-xl">
                                             <div class="icon-area text-5xl mr-6"></div>
                                             <div>
                                                 <h4 class="text-3xl md:text-4xl font-bold status-text mb-1"></h4>
                                                 <p class="text-2xl md:text-3xl opacity-90 detailed-text"></p>
                                             </div>
                                        </div>
                                    </div>
                                </div>
                             `).join('')}
                        </div>
                    </div>`;

                default: return '';
            }
        }

        // ====== INTERACTION LOGIC ======
        function renderApp() {
            const slide = slides[currentSlide];
            const app = document.getElementById('app');

            app.innerHTML = renderSlideContent(slide);
            document.getElementById('slide-counter').textContent = `${currentSlide + 1} / ${slides.length}`;

            if (slide.type === 'quiz') {
                attachQuizListeners(slide);
            }
        }

        function nextSlide() {
            if (currentSlide < slides.length - 1) {
                currentSlide++;
                renderApp();
            }
        }

        function prevSlide() {
            if (currentSlide > 0) {
                currentSlide--;
                renderApp();
            }
        }

        function attachQuizListeners(slide) {
            const quizOptions = document.querySelectorAll('.quiz-option');
            quizOptions.forEach(btn => {
                btn.addEventListener('click', () => {
                    const parent = btn.closest('.glass-panel');
                    const allBtns = parent.querySelectorAll('.quiz-option');
                    allBtns.forEach(b => b.disabled = true);

                    const qIndex = parseInt(btn.dataset.q, 10);
                    const chosenLetter = btn.dataset.letter;
                    const question = slide.content.questions[qIndex];
                    const isCorrect = chosenLetter === question.answer;

                    btn.classList.remove('bg-slate-800/50', 'hover:bg-blue-600/80');
                    if (isCorrect) {
                        btn.classList.add('bg-green-600', 'border-green-400', 'shadow-[0_0_20px_rgba(34,197,94,0.4)]');
                    } else {
                        btn.classList.add('bg-red-600', 'border-red-400');
                        const correctBtn = parent.querySelector(`.quiz-option[data-letter="${question.answer}"]`);
                        correctBtn.classList.remove('bg-slate-800/50');
                        correctBtn.classList.add('bg-green-600/50', 'border-green-400/50');
                    }

                    const answerBox = parent.querySelector('.quiz-answer');
                    const innerBox = answerBox.querySelector('div');
                    const iconArea = answerBox.querySelector('.icon-area');
                    const statusText = answerBox.querySelector('.status-text');
                    const detailText = answerBox.querySelector('.detailed-text');

                    answerBox.classList.remove('hidden');

                    if (isCorrect) {
                        innerBox.className = "rounded-2xl p-6 flex items-center border-l-8 border-green-400 bg-green-900/80 text-white shadow-xl";
                        iconArea.innerHTML = '<i class="fa-solid fa-circle-check text-green-400"></i>';
                        statusText.textContent = "Chính xác!";
                        detailText.textContent = `Đáp án ${question.answer} là đáp án đúng.`;
                    } else {
                        innerBox.className = "rounded-2xl p-6 flex items-center border-l-8 border-red-500 bg-red-900/80 text-white shadow-xl";
                        iconArea.innerHTML = '<i class="fa-solid fa-circle-xmark text-red-400"></i>';
                        statusText.textContent = "Chưa đúng";
                        detailText.textContent = `Đáp án đúng là ${question.answer}.`;
                    }
                });
            });
        }

        // Keyboard navigation
        document.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowRight' || e.key === 'Space') {
                nextSlide();
            } else if (e.key === 'ArrowLeft') {
                prevSlide();
            }
        });

        document.addEventListener('keydown', e => {
        if (e.key.toLowerCase() === 'h') {
            const bar = document.getElementById('controlBar');
            bar.style.display = bar.style.display === 'none' ? 'flex' : 'none';
        }
        });

        // Initial Render
        renderApp();

    </script>
</body>
</html>
